<Window
    x:Class="ConstructionOS.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Construction OS">
  <Grid>
    <NavigationView x:Name="Nav"
                    PaneDisplayMode="Left"
                    IsSettingsVisible="True"
                    IsBackButtonVisible="Collapsed"
                    Loaded="Nav_Loaded"
                    SelectionChanged="Nav_SelectionChanged">
      <NavigationView.PaneHeader>
        <StackPanel Margin="12,8" Spacing="8">
          <TextBlock Text="Construction OS"
                     Style="{StaticResource SubtitleTextBlockStyle}"/>
          <AutoSuggestBox x:Name="SearchBox"
                          PlaceholderText="Search tabs &amp; records"
                          QueryIcon="Find"
                          TextChanged="SearchBox_TextChanged"
                          SuggestionChosen="SearchBox_SuggestionChosen"
                          QuerySubmitted="SearchBox_QuerySubmitted"/>
        </StackPanel>
      </NavigationView.PaneHeader>
      <Frame x:Name="ContentFrame" Margin="12"/>
    </NavigationView>
  </Grid>
</Window>
