<Window
    x:Class="ConstructionOS.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="ACO">
  <Grid>
    <!-- Top ribbon: PaneDisplayMode="Top" renders the sections as a horizontal
         bar; NavigationView natively auto-collapses items that don't fit into a
         "More" (») overflow flyout as the window narrows. Section parents open
         a dropdown of their tabs. Stock control, no custom chrome. -->
    <NavigationView x:Name="Nav"
                    PaneDisplayMode="Top"
                    IsSettingsVisible="True"
                    IsBackButtonVisible="Collapsed"
                    Loaded="Nav_Loaded"
                    SelectionChanged="Nav_SelectionChanged">
      <NavigationView.PaneHeader>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock Text="ACO"
                     Style="{StaticResource SubtitleTextBlockStyle}"
                     Margin="4,0,8,0" VerticalAlignment="Center"/>
          <TextBlock Text="Accelerated Construction Operations"
                     Style="{StaticResource CaptionTextBlockStyle}"
                     Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                     VerticalAlignment="Center"/>
        </StackPanel>
      </NavigationView.PaneHeader>
      <NavigationView.AutoSuggestBox>
        <!-- U5 command palette: type to find any tab (GET /api/search), pick to
             navigate. Stock AutoSuggestBox in the NavigationView search slot. -->
        <AutoSuggestBox x:Name="Search" QueryIcon="Find"
                        PlaceholderText="Search tabs…"
                        TextChanged="Search_TextChanged"
                        SuggestionChosen="Search_SuggestionChosen"
                        QuerySubmitted="Search_QuerySubmitted"/>
      </NavigationView.AutoSuggestBox>
      <Frame x:Name="ContentFrame" Margin="12"/>
    </NavigationView>
  </Grid>
</Window>
