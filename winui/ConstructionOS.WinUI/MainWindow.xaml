<Window
    x:Class="ConstructionOS.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="ACO">
  <!-- Excel-style ribbon, built from the simplest stock primitives so nothing in
       the shell can native-crash: a horizontal row of ToggleButtons is the
       section tab strip (mutually exclusive, managed in code), and picking one
       fills the ribbon band below with that section's tabs as icon-over-label
       commands (AppBarButton). Always-on entries (Home/Assistant/Process/Tools)
       and Settings are leaf tabs that navigate directly with no band. Both the
       tab strip and the band sit in horizontal ScrollViewers, so a narrow window
       scrolls rather than clipping. (NavigationView Top / SelectorBar were both
       dropped: their overflow-measure code fail-fasts in Microsoft.ui.xaml.dll
       with 0xc000027b during layout on this Windows App SDK build.) -->
  <Grid RowDefinitions="Auto,Auto,*" Loaded="OnRootLoaded">
    <!-- Row 0: title | section tabs | search -->
    <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Padding="12,8,12,4"
          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
      <StackPanel Grid.Column="0" Orientation="Horizontal"
                  VerticalAlignment="Center" Margin="4,0,16,0">
        <TextBlock Text="ACO"
                   Style="{StaticResource SubtitleTextBlockStyle}"
                   VerticalAlignment="Center"/>
        <TextBlock Text="Accelerated Construction Operations"
                   Style="{StaticResource CaptionTextBlockStyle}"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   VerticalAlignment="Bottom" Margin="8,0,0,3"/>
      </StackPanel>
      <ScrollViewer Grid.Column="1" VerticalScrollMode="Disabled"
                    VerticalScrollBarVisibility="Disabled"
                    HorizontalScrollMode="Auto"
                    HorizontalScrollBarVisibility="Auto"
                    VerticalAlignment="Center">
        <StackPanel x:Name="Tabs" Orientation="Horizontal" Spacing="2"/>
      </ScrollViewer>
      <AutoSuggestBox Grid.Column="2" x:Name="Search" QueryIcon="Find" Width="240"
                      PlaceholderText="Search tabs…" VerticalAlignment="Center"
                      TextChanged="Search_TextChanged"
                      SuggestionChosen="Search_SuggestionChosen"
                      QuerySubmitted="Search_QuerySubmitted"/>
    </Grid>

    <!-- Row 1: ribbon command band for the selected section -->
    <Border x:Name="RibbonBand" Grid.Row="1"
            BorderThickness="0,0,0,1"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            Padding="8,4" Visibility="Collapsed">
      <ScrollViewer VerticalScrollMode="Disabled"
                    VerticalScrollBarVisibility="Disabled"
                    HorizontalScrollMode="Auto"
                    HorizontalScrollBarVisibility="Auto">
        <StackPanel x:Name="Ribbon" Orientation="Horizontal" Spacing="2"/>
      </ScrollViewer>
    </Border>

    <!-- Row 2: page content -->
    <Frame x:Name="ContentFrame" Grid.Row="2" Margin="12"/>
  </Grid>
</Window>
