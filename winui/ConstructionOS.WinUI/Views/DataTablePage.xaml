<Page
    x:Class="ConstructionOS.WinUI.Views.DataTablePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid RowDefinitions="Auto,Auto,*" Padding="8" RowSpacing="8">
    <TextBlock x:Name="TitleText" Grid.Row="0" Text="Records"
               Style="{StaticResource TitleTextBlockStyle}"/>
    <CommandBar Grid.Row="1" DefaultLabelPosition="Right"
                HorizontalAlignment="Left" Background="Transparent">
      <AppBarButton Icon="Refresh" Label="Refresh" Click="OnRefresh"/>
    </CommandBar>
    <Grid x:Name="Host" Grid.Row="2"/>
  </Grid>
</Page>
