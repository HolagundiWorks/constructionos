<Page
    x:Class="ConstructionOS.WinUI.Views.EvmPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI">
  <ScrollViewer Padding="8">
    <StackPanel Spacing="12">
      <TextBlock Text="Earned Value" Style="{StaticResource PageTitleStyle}"/>
      <TextBlock x:Name="Summary" TextWrapping="Wrap"
                 Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
      <!-- Per-project cost (CPI) and schedule (SPI) performance. 1.0 = on plan;
           below 1 is over cost / behind. Values from /api/evm — no maths in C#. -->
      <Border Height="320" Padding="4"
              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              CornerRadius="8">
        <lvc:CartesianChart x:Name="Chart" AutomationProperties.Name="Cost and schedule performance chart"/>
      </Border>
      <TextBlock x:Name="Status" TextWrapping="Wrap"
                 Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
      <StackPanel x:Name="Detail"/>
    </StackPanel>
  </ScrollViewer>
</Page>
