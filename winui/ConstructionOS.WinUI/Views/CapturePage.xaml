<Page
    x:Class="ConstructionOS.WinUI.Views.CapturePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid RowDefinitions="Auto,Auto,Auto,Auto,*" Padding="8">
    <TextBlock Text="Field capture" Style="{StaticResource PageTitleStyle}"/>
    <TextBlock x:Name="Status" Grid.Row="1" Margin="0,8,0,0" TextWrapping="Wrap"
               Text="Sidecar status loads from GET /api/sidecar/status"/>
    <ComboBox x:Name="KindBox" Grid.Row="2" Margin="0,8,0,0" Width="160"
              Header="Sidecar kind" SelectedIndex="0">
      <x:String>ocr</x:String>
      <x:String>stt</x:String>
      <x:String>vlm</x:String>
    </ComboBox>
    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
      <Button Content="Refresh sidecars" Click="Refresh_Click"/>
      <Button Content="Probe extract" Click="Extract_Click"/>
    </StackPanel>
    <ScrollViewer Grid.Row="4" Margin="0,12,0,0">
      <TextBlock x:Name="Detail" TextWrapping="Wrap" FontFamily="Cascadia Mono"/>
    </ScrollViewer>
  </Grid>
</Page>
