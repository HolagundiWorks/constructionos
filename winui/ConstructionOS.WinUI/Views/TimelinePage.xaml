<Page
    x:Class="ConstructionOS.WinUI.Views.TimelinePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid RowDefinitions="Auto,Auto,*" Padding="8" RowSpacing="8">
    <TextBlock Grid.Row="0" Text="Programme" Style="{StaticResource PageTitleStyle}"/>
    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
      <ComboBox x:Name="ProjectBox" Header="Project" MinWidth="240"
                AutomationProperties.Name="Project"
                SelectionChanged="OnProjectChanged"/>
      <AppBarButton Icon="Refresh" Label="Refresh" Click="OnRefresh"
                    LabelPosition="Collapsed" VerticalAlignment="Bottom"
                    AutomationProperties.Name="Refresh programme"
                    ToolTipService.ToolTip="Refresh"/>
    </StackPanel>
    <ScrollViewer Grid.Row="2">
      <StackPanel x:Name="Host" Spacing="12"/>
    </ScrollViewer>
  </Grid>
</Page>
