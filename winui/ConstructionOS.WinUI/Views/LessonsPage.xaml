<Page
    x:Class="ConstructionOS.WinUI.Views.LessonsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls">
  <Grid RowDefinitions="Auto,*" Padding="8">
    <TextBlock Text="Lessons Learned" Style="{StaticResource TitleTextBlockStyle}"/>
    <controls:DataGrid x:Name="Grid" Grid.Row="1" AutoGenerateColumns="True"
                       IsReadOnly="True" Margin="0,8,0,0"/>
  </Grid>
</Page>
