<Page
    x:Class="ConstructionOS.WinUI.Views.CashFlowPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI">
  <Grid RowDefinitions="Auto,Auto,*" Padding="8" RowSpacing="8">
    <TextBlock Grid.Row="0" Text="Cash Flow Forecast" Style="{StaticResource PageTitleStyle}"/>
    <CommandBar Grid.Row="1" DefaultLabelPosition="Right"
                HorizontalAlignment="Left" Background="Transparent">
      <AppBarButton Icon="Refresh" Label="Refresh" Click="OnRefresh"/>
    </CommandBar>
    <ScrollViewer Grid.Row="2">
      <StackPanel Spacing="12">
        <InfoBar x:Name="Warning" IsOpen="False" IsClosable="False"/>
        <StackPanel x:Name="Cards" Orientation="Horizontal" Spacing="12"/>
        <Border Height="300" Padding="4"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="8">
          <lvc:CartesianChart x:Name="Chart"/>
        </Border>
        <StackPanel x:Name="TableHost"/>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Page>
