<Page
    x:Class="ConstructionOS.WinUI.Views.MoneyPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid RowDefinitions="Auto,Auto,*" Padding="8">
    <TextBlock Text="Payments" Style="{StaticResource TitleTextBlockStyle}"/>
    <CommandBar Grid.Row="1" DefaultLabelPosition="Right" Margin="0,8,0,0">
      <AppBarButton Icon="Add" Label="New payment" Click="OnNew"/>
      <AppBarButton Icon="Refresh" Label="Refresh" Click="OnRefresh"/>
    </CommandBar>
    <Grid Grid.Row="2" RowDefinitions="Auto,*">
      <InfoBar x:Name="Notice" IsOpen="False" IsClosable="True"/>
      <ListView x:Name="Grid" Grid.Row="1" Margin="0,8,0,0" SelectionMode="Single"/>
    </Grid>
  </Grid>
</Page>
