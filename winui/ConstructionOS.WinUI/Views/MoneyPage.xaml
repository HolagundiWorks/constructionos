<Page
    x:Class="ConstructionOS.WinUI.Views.MoneyPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid RowDefinitions="Auto,Auto,Auto,*" Padding="8" RowSpacing="8">
    <TextBlock Text="Payments" Style="{StaticResource TitleTextBlockStyle}"/>
    <!-- U3: record a payment via a metadata-driven form (fields from
         GET /api/payments), POSTed to /api/payments — which posts it to the
         ledger through the Python engine. Stock CommandBar + ContentDialog. -->
    <CommandBar Grid.Row="1" DefaultLabelPosition="Right"
                HorizontalAlignment="Left" Background="Transparent" IsOpen="False">
      <AppBarButton x:Name="NewButton" Icon="Add" Label="New payment"
                    Click="OnNew"/>
      <AppBarButton Icon="Refresh" Label="Refresh" Click="OnRefresh"/>
    </CommandBar>
    <InfoBar Grid.Row="2" x:Name="Notice" IsOpen="False"/>
    <ListView Grid.Row="3" x:Name="Grid" SelectionMode="None"/>
  </Grid>
</Page>
