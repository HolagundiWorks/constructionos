<Page
    x:Class="ConstructionOS.WinUI.Views.ProductivityPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid RowDefinitions="Auto,Auto,Auto,*" Padding="8">
    <TextBlock Text="Productivity" Style="{StaticResource PageTitleStyle}"/>
    <TextBlock x:Name="Summary" Grid.Row="1" Margin="0,8,0,0" TextWrapping="Wrap"/>
    <TextBlock x:Name="Status" Grid.Row="2" Margin="0,4,0,0" TextWrapping="Wrap"/>
    <!-- Stock ListView (the CommunityToolkit DataGrid is UWP/WinUI-2 and crashes
         WinUI 3); readable "key: value" rows come from Ui.Lines. -->
    <ListView x:Name="Grid" Grid.Row="3" SelectionMode="Single" Margin="0,8,0,0"/>
  </Grid>
</Page>
