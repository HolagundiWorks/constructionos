<Page
    x:Class="ConstructionOS.WinUI.Views.ProductivityPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls">
  <Grid RowDefinitions="Auto,Auto,Auto,*" Padding="8">
    <TextBlock Text="Productivity" Style="{StaticResource TitleTextBlockStyle}"/>
    <TextBlock x:Name="Summary" Grid.Row="1" Margin="0,8,0,0" TextWrapping="Wrap"/>
    <TextBlock x:Name="Status" Grid.Row="2" Margin="0,4,0,0" TextWrapping="Wrap"/>
    <controls:DataGrid x:Name="Grid" Grid.Row="3" AutoGenerateColumns="True"
                       IsReadOnly="True" Margin="0,8,0,0"/>
  </Grid>
</Page>
