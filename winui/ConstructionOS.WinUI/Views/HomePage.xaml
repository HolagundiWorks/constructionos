<Page
    x:Class="ConstructionOS.WinUI.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ScrollViewer>
    <StackPanel Spacing="14" Padding="8">
      <TextBlock Text="Home" Style="{StaticResource PageTitleStyle}"/>
      <TextBlock x:Name="Status"
                 Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
      <!-- KPI stat cards (money snapshot from /api/kpi), built in code-behind
           and laid out in a horizontally scrolling band. Stock controls only. -->
      <ScrollViewer HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Disabled"
                    HorizontalScrollMode="Enabled">
        <StackPanel x:Name="Cards" Orientation="Horizontal" Spacing="12"/>
      </ScrollViewer>
      <TextBlock Text="Advisories" Style="{StaticResource SubtitleTextBlockStyle}"
                 Margin="0,8,0,0"/>
      <StackPanel x:Name="Advisories" Spacing="8"/>
    </StackPanel>
  </ScrollViewer>
</Page>
