<Page
    x:Class="ConstructionOS.WinUI.Views.ReviewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid RowDefinitions="Auto,Auto,*" Padding="8" RowSpacing="8">
    <TextBlock x:Name="TitleText" Grid.Row="0" Text="Weekly review"
               Style="{StaticResource TitleTextBlockStyle}"/>
    <CommandBar Grid.Row="1" DefaultLabelPosition="Right"
                HorizontalAlignment="Left" Background="Transparent">
      <AppBarButton Icon="Refresh" Label="Refresh" Click="OnRefresh"/>
    </CommandBar>
    <ScrollViewer Grid.Row="2">
      <StackPanel x:Name="Host" Spacing="10" MaxWidth="1000"/>
    </ScrollViewer>
  </Grid>
</Page>
