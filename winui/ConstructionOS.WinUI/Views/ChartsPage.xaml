<Page
    x:Class="ConstructionOS.WinUI.Views.ChartsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI">
  <!-- U4: KPI / cashflow / ageing from the JSON API — no maths in C#. -->
  <ScrollViewer Padding="8">
    <StackPanel Spacing="16">
      <TextBlock Text="Charts / Key Numbers" Style="{StaticResource TitleTextBlockStyle}"/>

      <TextBlock x:Name="KpiCaption" TextWrapping="Wrap"
                 Text="Money snapshot (GET /api/kpi)."/>
      <Border Height="300" Padding="4"
              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              CornerRadius="8">
        <lvc:CartesianChart x:Name="KpiChart"/>
      </Border>
      <TextBlock x:Name="KpiStatus" TextWrapping="Wrap" FontFamily="Consolas"/>

      <TextBlock Text="Cash-flow forecast" Style="{StaticResource SubtitleTextBlockStyle}"/>
      <TextBlock TextWrapping="Wrap"
                 Text="Weekly buckets from GET /api/cashflow (in / out / balance)."/>
      <Border Height="280" Padding="4"
              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              CornerRadius="8">
        <lvc:CartesianChart x:Name="CashflowChart"/>
      </Border>
      <TextBlock x:Name="CashflowStatus" TextWrapping="Wrap" FontFamily="Consolas"/>

      <TextBlock Text="Receivables ageing" Style="{StaticResource SubtitleTextBlockStyle}"/>
      <TextBlock TextWrapping="Wrap"
                 Text="Buckets from GET /api/ageing."/>
      <Border Height="260" Padding="4"
              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              CornerRadius="8">
        <lvc:CartesianChart x:Name="AgeingChart"/>
      </Border>
      <TextBlock x:Name="AgeingStatus" TextWrapping="Wrap" FontFamily="Consolas"/>
    </StackPanel>
  </ScrollViewer>
</Page>
