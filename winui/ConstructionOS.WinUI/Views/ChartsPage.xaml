<Page
    x:Class="ConstructionOS.WinUI.Views.ChartsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- U4: LiveCharts series bind on Windows; this page always shows API keys. -->
  <ScrollViewer Padding="8">
    <StackPanel Spacing="12">
      <TextBlock Text="Charts / Key Numbers" Style="{StaticResource TitleTextBlockStyle}"/>
      <TextBlock TextWrapping="Wrap"
                 Text="Numbers come from GET /api/kpi and /api/dashboard. Bind LiveCharts2 series locally — no maths in C#."/>
      <TextBlock x:Name="Status" TextWrapping="Wrap" FontFamily="Consolas"/>
    </StackPanel>
  </ScrollViewer>
</Page>
