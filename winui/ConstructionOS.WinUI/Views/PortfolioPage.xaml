<Page
    x:Class="ConstructionOS.WinUI.Views.PortfolioPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid RowDefinitions="Auto,Auto,*" Padding="8">
    <TextBlock Text="Portfolio" Style="{StaticResource PageTitleStyle}"/>
    <TextBlock x:Name="Headline" Grid.Row="1" Margin="0,8,0,0" TextWrapping="Wrap"/>
    <ListView x:Name="Grid" Grid.Row="2" Margin="0,8,0,0" SelectionMode="Single"/>
  </Grid>
</Page>
