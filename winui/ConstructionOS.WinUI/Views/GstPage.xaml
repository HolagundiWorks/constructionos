<Page
    x:Class="ConstructionOS.WinUI.Views.GstPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid RowDefinitions="Auto,Auto,*" Padding="8" RowSpacing="8">
    <TextBlock x:Name="TitleText" Grid.Row="0" Text="GST &amp; TDS"
               Style="{StaticResource PageTitleStyle}"/>
    <CommandBar Grid.Row="1" DefaultLabelPosition="Right"
                HorizontalAlignment="Left" Background="Transparent">
      <AppBarButton Icon="Refresh" Label="Refresh" Click="OnRefresh"/>
      <AppBarSeparator/>
      <!-- The CA handoff: the whole month as one CSV (or a printable HTML
           summary), built server-side by gst_export.pack. -->
      <AppBarButton x:Name="ExportButton" Icon="Save" Label="Export for CA"
                    Click="OnExport"/>
    </CommandBar>
    <InfoBar x:Name="Notice" Grid.Row="1" IsOpen="False" IsClosable="True"
             HorizontalAlignment="Right" MaxWidth="520"/>
    <ScrollViewer Grid.Row="2">
      <StackPanel x:Name="Host" Spacing="8"/>
    </ScrollViewer>
  </Grid>
</Page>
