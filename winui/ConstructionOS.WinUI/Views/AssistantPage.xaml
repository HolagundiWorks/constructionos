<Page
    x:Class="ConstructionOS.WinUI.Views.AssistantPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid RowDefinitions="Auto,Auto,Auto,*" Padding="8" RowSpacing="8">
    <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto" ColumnSpacing="4">
      <TextBlock Text="Assistant" Style="{StaticResource PageTitleStyle}"/>
      <!-- Fluent 2: TeachingTip for the trust boundary, on demand — not a
           permanent banner competing with the answer. -->
      <!-- Icon-only: named on the parent, ≥40x40 target (WCAG 2.5.8 / Fluent),
           and the glyph itself is Raw so it isn't spoken twice (B7). -->
      <Button Grid.Column="1" x:Name="AboutButton" Click="OnAbout"
              Background="Transparent" BorderThickness="0"
              VerticalAlignment="Center" MinWidth="40" MinHeight="40"
              AutomationProperties.Name="How the assistant works"
              ToolTipService.ToolTip="How the assistant works">
        <FontIcon Glyph="&#xE946;" FontSize="16"
                  AutomationProperties.AccessibilityView="Raw"/>
      </Button>
    </Grid>

    <StackPanel Grid.Row="1" x:Name="Quick" Orientation="Horizontal" Spacing="12"/>

    <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="8">
      <TextBox x:Name="Ask" Grid.Column="0"
               PlaceholderText="Ask about your data — e.g. total received from clients this month"
               AutomationProperties.Name="Ask the assistant"
               KeyDown="OnKey" VerticalAlignment="Center"/>
      <Button x:Name="AskButton" Grid.Column="1" Content="Ask" Click="OnAsk"
              Style="{StaticResource AccentButtonStyle}" VerticalAlignment="Center"/>
    </Grid>

    <ScrollViewer Grid.Row="3">
      <StackPanel x:Name="Answer" Spacing="8"/>
    </ScrollViewer>

    <TeachingTip x:Name="AboutTip" Target="{x:Bind Ask}"
                 Title="It reads — it never writes"
                 Subtitle="The assistant turns your question into one read-only query over your own book, then summarises the rows it found. It cannot change money, dates or records. The four figures above are exact and work even with the AI engine off.">
    </TeachingTip>
  </Grid>
</Page>
