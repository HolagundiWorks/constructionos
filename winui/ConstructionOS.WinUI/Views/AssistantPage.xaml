<Page
    x:Class="ConstructionOS.WinUI.Views.AssistantPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid RowDefinitions="Auto,Auto,Auto,*" Padding="8" RowSpacing="8">
    <TextBlock Grid.Row="0" Text="Assistant" Style="{StaticResource PageTitleStyle}"/>
    <StackPanel Grid.Row="1" x:Name="Quick" Orientation="Horizontal" Spacing="12"/>
    <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="8">
      <TextBox x:Name="Ask" Grid.Column="0"
               PlaceholderText="Ask about your data — e.g. total received from clients this month"
               AutomationProperties.Name="Ask the assistant"
               KeyDown="OnKey" VerticalAlignment="Center"/>
      <Button x:Name="AskButton" Grid.Column="1" Content="Ask" Click="OnAsk"
              Style="{StaticResource AccentButtonStyle}" VerticalAlignment="Center"/>
    </Grid>
    <ScrollViewer Grid.Row="3">
      <StackPanel x:Name="Answer" Spacing="8"/>
    </ScrollViewer>
  </Grid>
</Page>
