# Runtime user data — created next to the code on first run, never source.
construction.db
construction_app/construction.db

# Extra company files (multi-firm / multi-year) and the registry that lists
# them. All user data, created at runtime beside the code.
construction_app/*.db
construction_app/companies.json
construction_app/firm_logo.png

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Ollama Manager runtime settings (user data)
ollama_manager/settings.json

# Installer build artifacts (the scripts are tracked; their output is not)
installer/build/
installer/dist/
installer/output/
installer/venv/
demo.db
